  "warnings.mixin_apply": "\u003cstrong\u003eMod $MOD$ is likely incompatible with this Minecraft version.\u003c/strong\u003e\n\nTo fix, do one of the following:\n1) Find a mod version that is compatible with this Minecraft version\n2) Disable or remove the mod until an update makes it compatible\n3) Use a Fabulously Optimized version that matches the mod\u0027s expected Minecraft version",
  "gui.privacy.logs_upload_decline": "No, don\u0027t upload",
  "gui.privacy.declined": "You chose not to upload the log(s). You can still share individual files manually, or click the button again.",
  "warnings.mixin_apply_common_start": "",
  "gui.file_list_label": "Logs"
}
