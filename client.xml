  "warnings.mixin_apply_common_end": "\n\n\u003ci\u003e¿Necesitas más ayuda? Haz clic en OK y sigue las instrucciones en la ventana principal.\u003c/i\u003e",
  "gui.menu.privacy.logs_info": "Política de Privacidad del Asistente de Crasheos",
  "gui.menu.file.open_config_folder": "carpeta config",
