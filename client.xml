  "gui.upload_all_button": "Upload and copy all logs",
  "warnings.mixin_apply_java_version": "\u003cstrong\u003eMod $MOD$ requires Java $REQUIRED_JAVA_VERSION$, but you are using Java $CURRENT_JAVA_VERSION$.\u003c/strong\u003e\n\nTo fix, do one of the following:\n1) Verify that you have installed or updated Fabulously Optimized properly\n2) Find a mod version that is compatible with this Minecraft and Java version\n3) Disable or remove the mod until an update makes it compatible\n4) Use a Fabulously Optimized version that matches the mod\u0027s expected Minecraft and Java version",
  "warnings.mixin_apply_common_end": "\n\n\u003ci\u003eNeed more help? Click OK and follow instructions on the main window.\u003c/i\u003e",
  "gui.intel_corrupted_microcode_bad": "Your BIOS/UEFI is outdated and you should update it as soon as possible.\n\u003ci\u003e(Your current microcode version is $MICROCODE_VERSION_CURRENT$, which is lower than the recommended version $MICROCODE_VERSION_FIXED$.)\u003c/i\u003e",
  "gui.comment_under_title_pls_report": "If you\u0027ve added extra content, ensure it is compatible with your Minecraft version.\n",
  "warnings.mixin_apply_conflicting_with_jar": "$LANG.warnings.mixin_apply_conflicting$",
  "gui.piracy_warning": "Offline mode detected",
  "warnings.mixin_apply_missing_class_auto_fix": "Find which mod is missing another mod",
  "gui.logs_analyzer": "Problem cause found!",
  "gui.menu.file.open_modpack_folder": "Open .minecraft folder",
  "gui.show_in_explorer_button": "Folder",
  "gui.privacy.logs_upload_question": "Your log(s) will be uploaded to \u003cb\u003emclo.gs\u003c/b\u003e, which removes some identifying information and stores the log(s) for 90 days.\nDo you accept the $LINK.PRIVACY_POLICY$?",
  "gui.simple_mode.prompt_question": "The logs will be shown individually so you can resolve the issue yourself.\nWould you like to see individual logs every time you get a crash?",
  "gui.title_crashed_with_report": "Fabulously Optimized crashed!",
  "gui.menu.file.open_config": "Crash Assistant settings",
  "warnings.mixin_config_missing_or_corrupted": "\u003cstrong\u003eMod $MOD$ is likely broken.\u003c/strong\u003e\n\nTo fix, do one of the following:\n1) Download the mod again\n2) Download a different version of the mod that is compatible with this Minecraft version\n3) Disable or remove the mod until an update makes it compatible",
  "gui.upload_and_copy_link_button": "Upload and copy",
  "gui.privacy.consent_reset_success": "Crash Assistant will now ask you before uploading logs.",
  "gui.privacy.logs_upload_accept": "Yes, upload to mclo.gs",
  "gui.simple_mode.button": "I\u0027ll fix it myself",
  "gui.comment_under_title": "1) Join \u003ca href\u003d\"https://download.fo/discord\"\u003eFabulously Optimized Discord\u003c/a\u003e.\n2) Start a new post in \u003cb\u003e#support\u003c/b\u003e.\n3) Describe what you were doing before the crash, add a title, and tag it \"\u003cb\u003eCrash\u003c/b\u003e\".\n4) \u003cb\u003eUpload and copy all logs\u003c/b\u003e, and paste them into the post description.\n5) Wait for help — we\u0027ll tell you if we need more information.",
  "msg.crashed": " Crash logs:",
  "gui.intel_corrupted_msg": "Your Intel CPU has a known defect. Ensure that your BIOS/UEFI is up to date to prevent physical damage and random crashes in the system.\n\n$CURRENT_MICROCODE_TEXT$\n\nClick Learn More to read what you can do, otherwise click OK.",
  "warnings.piracy": "You are using an unsupported launcher or offline mode.\n\nIf you need help with this crash, please try \u003ca href\u003d\"https://download.fo/install/\"\u003einstalling a supported launcher\u003c/a\u003e or switching to online mode, then repeating the actions that led to the crash.\nWe do not provide support for crashes that happen in offline mode.",
  "gui.upload_all_finished_button": "$LANG.gui.upload_all_button$",
