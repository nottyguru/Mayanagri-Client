<file path="files/config/crash_assistant/crash_assistant_localization_overrides/ms_my.json">
{
  "gui.intel_corrupted_microcode_good": "BIOS/UEFI anda telah dikemas kini. Jika anda masih mengalami ranap sistem di luar Minecraft, semak pilihan jaminan anda.\n\u003ci\u003e(Versi mikrokod anda ialah $MICROCODE_VERSION_CURRENT$ yang memenuhi versi minimum yang disyorkan iaitu $MICROCODE_VERSION_FIXED$.)\u003c/i\u003e",
  "gui.request_help_button": "Pelayan Discord Fabulously Optimized",
  "warnings.mixin_apply_missing_class": "\u003cstrong\u003eTerdapat mod yang hilang yang diperlukan oleh mod yang lain. Kelas yang hilang: $MISSING_CLASS$\u003c/strong\u003e\n\nUntuk membetulkan masalah ini, lakukan salah satu daripada yang berikut:\n1) Tekan butang di bawah dan gunakan tetingkap untuk mengetahui nama mod. Kemudian cari senarai mod dan baca penerangannya untuk mengetahui keperluannya.\n2) Tekan butang di bawah, gunakan tetingkap dan ambil tangkapan layar tersebut. Kemudian kembali ke tetingkap ranap utama, ikuti arahan dan lampirkan tangkapan layar, supaya kami dapat membantu anda menyelesaikan masalah tersebut.",
  "gui.menu.privacy.reset_consent": "Prom sebelum memuat naik log",
  "gui.intel_corrupted_title": "Kecacatan CPU dikesan",
  "warnings.mixin_apply_conflicting": "\u003cstrong\u003eMod $MOD$ mungkin tidak boleh digunakan dengan mod $MOD_2$.\u003c/strong\u003e\n\nUntuk membetulkan masalah ini, nyahdayakan atau alih keluar salah satu mod tersebut.",
  "gui.window_name": "$LANG.gui.title_crashed_with_report$ - Crash Assistant",
  "gui.upload_all_button_delayed": "Sedang mencari log... ($SECONDS$ s)",
  "gui.upload_all_button": "Muat naik dan salin semua log",
  "warnings.mixin_apply_java_version": "\u003cstrong\u003eMod $MOD$ memerlukan Java $REQUIRED_JAVA_VERSION$, tetapi anda sedang menggunakan Java $CURRENT_JAVA_VERSION$.\u003c/strong\u003e\n\nUntuk membetulkan masalah ini, lakukan salah satu daripada yang berikut:\n1) Sahkan bahawa anda telah memasang atau mengemas kini Fabulously Optimized dengan betul\n2) Cari versi mod tersebut yang serasi dengan versi Minecraft dan Java ini\n3) Nyahdayakan atau alih keluar mod tersebut sehingga terdapat kemas kini yang menjadikannya serasi\n4) Gunakan versi Fabulously Optimized yang sepadan dengan versi Minecraft dan Java yang dijangka oleh mod tersebut",
  "warnings.mixin_apply_common_end": "\n\n\u003ci\u003ePerlukan bantuan lanjut? Klik OK dan ikuti arahan pada tetingkap utama.\u003c/i\u003e",
  "gui.intel_corrupted_microcode_bad": "BIOS/UEFI anda sudah ketinggalan zaman dan anda perlu mengemas kininya secepat mungkin.\n\u003ci\u003e(Versi mikrokod semasa anda ialah $MICROCODE_VERSION_CURRENT$ yang lebih rendah daripada versi yang disyorkan iaitu $MICROCODE_VERSION_FIXED$.)\u003c/i\u003e",
  "gui.comment_under_title_pls_report": "Jika anda telah menambah mod tambahan, pastikan ia serasi dengan versi Minecraft anda.\n",
  "gui.piracy_warning": "Mod luar talian dikesan",
  "warnings.mixin_apply_missing_class_auto_fix": "Cari mod manakah yang memerlukan mod yang hilang",
  "gui.logs_analyzer": "Penyebab masalah ditemui!",
  "gui.menu.file.open_modpack_folder": "Buka folder .minecraft",
  "gui.show_in_explorer_button": "Folder",
  "gui.privacy.logs_upload_question": "Log anda akan dimuat naik ke \u003cb\u003emclo.gs\u003c/b\u003e yang akan menyimpan log tersebut selama 90 hari dan mengalih keluar beberapa maklumat pengecam.\nAdakah anda menerima $LINK.PRIVACY_POLICY$?",
  "gui.simple_mode.prompt_question": "Semua log akan ditunjukkan secara individu supaya anda boleh menyelesaikan masalah tersebut sendiri.\nAdakah anda ingin melihat kesemua log secara individu setiap kali anda mengalami ranap permainan?",
  "gui.title_crashed_with_report": "Fabulously Optimized telah ranap!",
  "gui.menu.file.open_config": "Tetapan Crash Assistant",
  "warnings.mixin_config_missing_or_corrupted": "\u003cstrong\u003eMod $MOD$ berkemungkinan rosak.\u003c/strong\u003e\n\nUntuk membetulkan masalah ini, lakukan salah satu daripada yang berikut:\n1) Muat turun mod tersebut sekali lagi\n2) Muat turun versi lain mod tersebut yang serasi dengan versi Minecraft ini\n3) Nyahdayakan atau alih keluar mod sehingga terdapat kemas kini yang menjadikannya serasi",
  "gui.upload_and_copy_link_button": "Muat naik dan salin",
  "gui.privacy.consent_reset_success": "Crash Assistant kini akan bertanya kepada anda sebelum memuat naik log.",
  "gui.privacy.logs_upload_accept": "Ya, muat naik ke mclo.gs",
  "gui.menu.file.open_mods_folder": "Buka folder mods",
  "gui.simple_mode.button": "Saya akan membaikinya sendiri",
  "gui.comment_under_title": "1) Sertai \u003ca href\u003d\"https://download.fo/discord\"\u003epelayan Discord Fabulously Optimized\u003c/a\u003e.\n2) Mulakan siaran baharu di \u003cb\u003e#support\u003c/b\u003e.\n3) Terangkan apa yang anda lakukan sebelum ranap permainan berlaku, letakkan tajuk, dan tambahkan tag \"\u003cb\u003eCrash\u003c/b\u003e\"\n4) \u003cb\u003eMuat naik dan salin semua log\u003c/b\u003e, dan tampalkannya ke dalam keterangan siaran.\n5) Tunggu bantuan tiba — kami akan memberitahu anda jika kami memerlukan lebih banyak maklumat.",
  "gui.intel_corrupted_msg": "CPU Intel anda mempunyai kecacatan yang diketahui. Pastikan BIOS/UEFI anda dikemas kini untuk mengelakkan kerosakan fizikal dan ranap sistem secara rawak.\n\n$CURRENT_MICROCODE_TEXT$\n\nKlik Ketahui Lebih Lanjut untuk membaca apa yang boleh anda lakukan, sebaliknya klik OK.",
  "warnings.piracy": "Anda sedang menggunakan mod luar talian atau sebuah pelancar yang tidak disokong.\n\nJika anda memerlukan bantuan dengan ranap permainan ini, sila cuba \u003ca href\u003d\"https://download.fo/install/\"\u003ememasang salah satu pelancar yang disokong\u003c/a\u003e atau bertukar kepada mod dalam talian, kemudian mengulangi tindakan yang menyebabkan ranap permainan tersebut.\nKami tidak menyediakan sokongan untuk ranap permainan yang berlaku dalam mod luar talian.",
  "gui.privacy.consent_not_given": "Crash Assistant sudah bertanya kepada anda sebelum memuat naik log.",
  "warnings.mixin_apply": "\u003cstrong\u003eMod $MOD$ mungkin tidak serasi dengan versi Minecraft ini.\u003c/strong\u003e\n\nUntuk membetulkan masalah ini, lakukan salah satu daripada yang berikut:\n1) Cari versi mod tersebut yang serasi dengan versi Minecraft ini\n2) Nyahdayakan atau alih keluar mod tersebut sehingga terdapat kemas kini yang menjadikannya serasi\n3) Gunakan versi Fabulously Optimized yang sepadan dengan versi Minecraft yang dijangka oleh mod tersebut",
  "gui.menu.file.open_config_folder": "Buka folder config",
  "gui.privacy.logs_upload_decline": "Tidak, jangan muat naik",
  "gui.privacy.declined": "Anda memilih untuk tidak memuat naik log tersebut. Anda masih boleh berkongsi fail-fail tersebut secara manual, atau klik butang tersebut sekali lagi.",
  "warnings.mixin_apply_common_start": "",
  "gui.file_list_label": "Log"
}
